<UserControl x:Class="Gpt2Image.Wpf.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="模型与连接设置" Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock Text="为小智 AI Studio 维护图像、视频、日常对话和 AI 编码的多供应商模型配置。"
                           Style="{StaticResource PageSubtitleTextStyle}" />
                <TextBlock Text="{Binding Status}" Style="{StaticResource StatusTextBlockStyle}" Margin="0,6,24,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="保存配置" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" VerticalAlignment="Top" Margin="18,4,0,0" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid MaxWidth="1020">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" MinWidth="320" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" MinWidth="520" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="配置用途" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="先选择要配置的功能，下面的供应商和协议会按该功能能力自动过滤。" Style="{StaticResource SectionSubtitleTextStyle}" Margin="0,4,0,14" />
                            <ComboBox ItemsSource="{Binding RoleOptions}"
                                      SelectedValue="{Binding SelectedProfileRole, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="Label" />
                            <Border Style="{StaticResource MutedSectionCardStyle}" Margin="0,12,0,0">
                                <TextBlock Text="{Binding SelectedProfileRoleDescription}" Style="{StaticResource MutedTextStyle}" FontSize="12" />
                            </Border>
                            <TextBlock Text="{Binding ProviderSectionTitle}" FontWeight="SemiBold" Margin="0,16,0,8" />
                            <ComboBox ItemsSource="{Binding ProviderOptions}"
                                      SelectedValue="{Binding SelectedProviderKind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="Label"
                                      materialDesign:HintAssist.Hint="按功能过滤后的供应商" />
                            <Border Style="{StaticResource MutedSectionCardStyle}" Margin="0,10,0,0">
                                <TextBlock Text="{Binding SelectedProviderDescription}" Style="{StaticResource MutedTextStyle}" FontSize="12" TextWrapping="Wrap" />
                            </Border>
                            <Button Content="应用该供应商接口预设" Command="{Binding ApplyProviderPresetCommand}" Style="{StaticResource SmallActionButtonStyle}" HorizontalAlignment="Right" Margin="0,10,0,0" />

                            <TextBlock Text="已保存配置" FontWeight="SemiBold" Margin="0,16,0,8" />
                            <ComboBox ItemsSource="{Binding Profiles}"
                                      SelectedItem="{Binding SelectedProfile}"
                                      DisplayMemberPath="DisplayText"
                                      materialDesign:HintAssist.Hint="选择已有供应商配置" />
                            <TextBlock Text="{Binding SelectedProfile.DetailText}" Style="{StaticResource SectionSubtitleTextStyle}" Margin="0,4,0,0" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                <Button Content="新建配置" Command="{Binding NewProfileCommand}" Style="{StaticResource SmallActionButtonStyle}" Margin="0,0,8,0" />
                                <Button Content="刷新列表" Command="{Binding RefreshProfilesCommand}" Style="{StaticResource SmallActionButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="运行策略" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="并发数越高吞吐越大，也更容易触发供应商限流。" Style="{StaticResource SectionSubtitleTextStyle}" Margin="0,4,0,14" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="并发数" FontWeight="SemiBold" />
                                    <TextBlock Text="建议从 1-2 开始，确认后端稳定后再提高。" Style="{StaticResource SectionSubtitleTextStyle}" />
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding Concurrency, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                            </Grid>
                            <Button Content="保存当前角色配置" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,18,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="连接" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Text="这里保存的是当前用途的后端连接信息。密钥只在本地配置中使用。" Style="{StaticResource SectionSubtitleTextStyle}" />
                            </StackPanel>

                            <Border Grid.Row="1" Style="{StaticResource MutedSectionCardStyle}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="名称" FontWeight="SemiBold" />
                                        <TextBlock Text="用于区分不同供应商或账号。" Style="{StaticResource SectionSubtitleTextStyle}" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource MutedSectionCardStyle}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="接口地址" FontWeight="SemiBold" />
                                        <TextBlock Text="OpenAI-compatible 通常形如 https://host/v1。" Style="{StaticResource SectionSubtitleTextStyle}" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="3" Style="{StaticResource MutedSectionCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="API 密钥" FontWeight="SemiBold" />
                                        <TextBlock Text="保存后供对应功能调用。" Style="{StaticResource SectionSubtitleTextStyle}" />
                                    </StackPanel>
                                    <PasswordBox Grid.Column="1" x:Name="ApiKeyBox" PasswordChanged="OnPasswordChanged" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="供应商、模型与协议" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Text="{Binding ProviderSectionHint}" Style="{StaticResource SectionSubtitleTextStyle}" />
                            </StackPanel>

                            <Border Grid.Row="1" Style="{StaticResource MutedSectionCardStyle}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ProviderSectionTitle}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ProviderSectionHint}" Style="{StaticResource SectionSubtitleTextStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <ComboBox ItemsSource="{Binding ProviderOptions}"
                                                  SelectedValue="{Binding SelectedProviderKind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Value"
                                                  DisplayMemberPath="Label" />
                                        <TextBlock Text="{Binding SelectedProviderDescription}" Style="{StaticResource SectionSubtitleTextStyle}" TextWrapping="Wrap" />
                                        <Button Content="重新应用预设" Command="{Binding ApplyProviderPresetCommand}" Style="{StaticResource SmallActionButtonStyle}" HorizontalAlignment="Right" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource MutedSectionCardStyle}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="接口协议" FontWeight="SemiBold" />
                                        <TextBlock Text="协议列表会按当前功能过滤，避免把纯聊天接口用于图片或视频。" Style="{StaticResource SectionSubtitleTextStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <ComboBox ItemsSource="{Binding ProtocolOptions}"
                                                  SelectedValue="{Binding SelectedProtocol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Value"
                                                  DisplayMemberPath="Label" />
                                        <TextBlock Text="{Binding SelectedProtocolDescription}" Style="{StaticResource SectionSubtitleTextStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="3" Style="{StaticResource MutedSectionCardStyle}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="主模型" FontWeight="SemiBold" />
                                        <TextBlock Text="对话、提示词优化和编码默认使用。" Style="{StaticResource SectionSubtitleTextStyle}" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Text="{Binding MainlineModel, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="4" Style="{StaticResource MutedSectionCardStyle}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="图像模型" FontWeight="SemiBold" />
                                        <TextBlock Text="图片生成/编辑使用。" Style="{StaticResource SectionSubtitleTextStyle}" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Text="{Binding ImageModel, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="5" Style="{StaticResource MutedSectionCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="视频模型" FontWeight="SemiBold" />
                                        <TextBlock Text="Routin xAI Video 默认推荐 grok-imagine-video。" Style="{StaticResource SectionSubtitleTextStyle}" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Text="{Binding VideoModel, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
