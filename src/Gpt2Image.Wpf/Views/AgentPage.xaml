<UserControl x:Class="Gpt2Image.Wpf.Views.AgentPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="自动任务" FontSize="28" FontWeight="SemiBold" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="520" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="300" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <Border BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" Background="{StaticResource PanelBrush}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="目标" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                    <TextBox Grid.Row="1"
                             Text="{Binding Goal, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Border>

            <Border Grid.Column="2" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" Background="{StaticResource PanelBrush}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="运行参数" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />

                    <CheckBox Grid.Row="1" Content="联网搜索" IsChecked="{Binding UseWebSearch}" Margin="0,0,0,14" />

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="最大轮次" FontWeight="SemiBold" />
                        <TextBox Text="{Binding MaxRounds, UpdateSourceTrigger=PropertyChanged}" Margin="0,7,0,18" />
                        <Button Content="运行" Command="{Binding RunCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>

                    <TextBlock Grid.Row="3" Text="{Binding Status}" Style="{StaticResource StatusTextBlockStyle}" Margin="0,16,0,0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
