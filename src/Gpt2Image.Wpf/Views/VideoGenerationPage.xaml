<UserControl x:Class="Gpt2Image.Wpf.Views.VideoGenerationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Gpt2Image.Wpf.Controls"
             xmlns:converters="clr-namespace:Gpt2Image.Wpf.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="PreviewActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallActionButtonStyle}" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="420" />
            <RowDefinition Height="170" MinHeight="130" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="AI 视频创作" Style="{StaticResource PageTitleTextStyle}" />
            <TextBlock Text="基于视频生成 API，提交后自动轮询；生成结果不默认保存，可在线播放，点击另存为时再保存。" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0" />
            <TextBlock Text="{Binding Status}" Style="{StaticResource StatusTextBlockStyle}" Margin="0,5,24,0" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" MinWidth="340" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" MinWidth="540" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="视频参数" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="图片输入按 Routin 文档使用 URL，不上传本地图片。" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,8,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="提示词" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="润色视频提示词"
                                        Command="{Binding OptimizePromptCommand}"
                                        MinWidth="120"
                                        Padding="10,4" />
                            </Grid>
                            <TextBox Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="160"
                                     Margin="0,7,0,8" />
                            <ProgressBar Height="3"
                                         IsIndeterminate="True"
                                         Visibility="{Binding IsOptimizingPrompt, Converter={StaticResource BoolToVisibilityConverter}}"
                                         Margin="0,0,0,14" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="比例" FontWeight="SemiBold" />
                                    <ComboBox ItemsSource="{Binding AspectRatios}" SelectedItem="{Binding AspectRatio}" Margin="0,7,0,14" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="分辨率" FontWeight="SemiBold" />
                                    <ComboBox ItemsSource="{Binding Resolutions}" SelectedItem="{Binding Resolution}" Margin="0,7,0,14" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="时长（秒）" FontWeight="SemiBold" />
                            <TextBox Text="{Binding Duration, UpdateSourceTrigger=PropertyChanged}" Margin="0,7,0,14" />

                            <Border Style="{StaticResource MutedSectionCardStyle}" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="起始图片 URL（可选）" FontWeight="SemiBold" />
                                    <TextBlock Text="用于 image-to-video；不能和参考图片 URL 同时填写。" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,3,0,7" />
                                    <TextBox Text="{Binding ImageUrl, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource MutedSectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="参考图片 URL（可选，最多 7 张）" FontWeight="SemiBold" />
                                    <TextBlock Text="每行一个 URL；不能和起始图片 URL 同时填写。" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,3,0,7" />
                                    <TextBox Text="{Binding ReferenceImageUrlsText, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             MinHeight="90" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="0,16,0,0">
                        <ProgressBar Height="4" IsIndeterminate="True" Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,12" />
                        <Button Content="开始生成视频" Command="{Binding GenerateVideoCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="视频结果" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="生成完成后可直接在线播放；需要本地文件时点击另存为。" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding PreviewVideos}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemWidth="430" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="420" Height="360" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" CornerRadius="16" Background="#F8FAFC" Margin="0,0,14,14">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="另存为..." Command="{Binding SaveAsCommand}" />
                                                <MenuItem Header="打开文件" Command="{Binding OpenFileCommand}" />
                                                <MenuItem Header="打开文件夹" Command="{Binding OpenFolderCommand}" />
                                                <MenuItem Header="复制路径" Command="{Binding CopyPathCommand}" />
                                                <MenuItem Header="复制链接" Command="{Binding CopySourceUrlCommand}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="220" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Grid Background="#EEF2F7">
                                                <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center" Margin="18">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10" />
                                                    <ProgressBar IsIndeterminate="True" Height="4" Width="150" />
                                                </StackPanel>
                                                <controls:VideoPlayerControl x:Name="VideoPanel"
                                                                             Source="{Binding PlaybackSource}"
                                                                             Visibility="Collapsed" />
                                                <Border x:Name="ErrorPanel" Background="#FEF2F2" Visibility="Collapsed" Padding="14">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <TextBlock Text="{Binding Status}" Foreground="#991B1B" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" />
                                                    </ScrollViewer>
                                                </Border>
                                            </Grid>

                                            <Border Grid.Row="1" Background="#FFFFFF" Padding="10">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                        <TextBlock Grid.Column="1" Text="{Binding FileName}" Foreground="{StaticResource TextSecondaryBrush}" MaxWidth="190" TextTrimming="CharacterEllipsis" />
                                                    </Grid>
                                                    <TextBlock Grid.Row="1" Text="{Binding Status}" Foreground="#475569" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Margin="0,5,0,0" />
                                                    <UniformGrid Grid.Row="2" Columns="5" Margin="0,10,0,0">
                                                        <Button Content="另存为" Command="{Binding SaveAsCommand}" Style="{StaticResource PreviewActionButtonStyle}" Margin="0,0,6,0" />
                                                        <Button Content="复制链接" Command="{Binding CopySourceUrlCommand}" Style="{StaticResource PreviewActionButtonStyle}" Margin="0,0,6,0" />
                                                        <Button Content="打开" Command="{Binding OpenFileCommand}" Style="{StaticResource PreviewActionButtonStyle}" Margin="0,0,6,0" />
                                                        <Button Content="文件夹" Command="{Binding OpenFolderCommand}" Style="{StaticResource PreviewActionButtonStyle}" Margin="0,0,6,0" />
                                                        <Button Content="复制路径" Command="{Binding CopyPathCommand}" Style="{StaticResource PreviewActionButtonStyle}" />
                                                    </UniformGrid>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSaved}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#16A34A" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HasError}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#DC2626" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding HasVideo}" Value="True">
                                            <Setter TargetName="VideoPanel" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="LoadingPanel" Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasError}" Value="True">
                                            <Setter TargetName="LoadingPanel" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="ErrorPanel" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}" Margin="0,18,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="日志" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding RunLogs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EDF0F4" BorderThickness="0,0,0,1" Padding="0,0,0,7" Margin="0,0,0,7">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="76" />
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TimeText}" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Level}" FontWeight="SemiBold" Foreground="#334155" />
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{Binding Message}" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
