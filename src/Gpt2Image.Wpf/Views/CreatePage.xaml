<UserControl x:Class="Gpt2Image.Wpf.Views.CreatePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Gpt2Image.Wpf.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:Base64ImageSourceConverter x:Key="Base64ImageSourceConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="360" />
            <RowDefinition Height="190" MinHeight="150" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="创作" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Status}" Style="{StaticResource StatusTextBlockStyle}" Margin="0,5,24,0" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" MinWidth="320" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" MinWidth="420" />
            </Grid.ColumnDefinitions>

            <Border BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" Background="{StaticResource PanelBrush}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="参数" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="提示词" FontWeight="SemiBold" />
                            <TextBox Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="170"
                                     Margin="0,7,0,14" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="尺寸" FontWeight="SemiBold" />
                                    <ComboBox ItemsSource="{Binding Sizes}" SelectedItem="{Binding Size}" Margin="0,7,0,14" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="数量" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}" Margin="0,7,0,14" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="质量" FontWeight="SemiBold" />
                            <ComboBox ItemsSource="{Binding Qualities}" SelectedItem="{Binding Quality}" Margin="0,7,0,14" />

                            <TextBlock Text="返回格式" FontWeight="SemiBold" />
                            <ComboBox ItemsSource="{Binding ResponseFormats}" SelectedItem="{Binding ResponseFormat}" Margin="0,7,0,14" />
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="0,16,0,0">
                        <ProgressBar Height="4" IsIndeterminate="True" Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,12" />
                        <Button Content="开始生成" Command="{Binding GenerateCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" Background="{StaticResource PanelBrush}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="预览" FontSize="18" FontWeight="SemiBold" />
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PreviewImages}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="260" Height="322" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" Background="#F8FAFC" Margin="0,0,14,14">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="230" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Grid Background="#EEF2F7">
                                                <Image x:Name="PreviewImage"
                                                       Source="{Binding PreviewBase64, Converter={StaticResource Base64ImageSourceConverter}}"
                                                       Stretch="Uniform"
                                                       Visibility="Collapsed" />

                                                <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center" Margin="18">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10" />
                                                    <ProgressBar IsIndeterminate="True" Height="4" Width="150" />
                                                </StackPanel>

                                                <Border x:Name="ErrorPanel" Background="#FEF2F2" Visibility="Collapsed" Padding="14">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <TextBlock Text="{Binding Status}" Foreground="#991B1B" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" />
                                                    </ScrollViewer>
                                                </Border>
                                            </Grid>

                                            <Border Grid.Row="1" Background="#FFFFFF" Padding="10">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                        <TextBlock Grid.Column="1" Text="{Binding FileName}" Foreground="{StaticResource TextSecondaryBrush}" MaxWidth="122" TextTrimming="CharacterEllipsis" />
                                                    </Grid>
                                                    <TextBlock Grid.Row="1" Text="{Binding Status}" Foreground="#475569" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Margin="0,5,0,0" />
                                                </Grid>
                                            </Border>
                                        </Grid>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSaved}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#16A34A" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HasError}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#DC2626" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding HasImage}" Value="True">
                                            <Setter TargetName="PreviewImage" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="LoadingPanel" Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasError}" Value="True">
                                            <Setter TargetName="LoadingPanel" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="ErrorPanel" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" Background="{StaticResource PanelBrush}" Padding="14" Margin="0,18,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="日志" FontSize="16" FontWeight="SemiBold" />
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding RunLogs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EDF0F4" BorderThickness="0,0,0,1" Padding="0,0,0,7" Margin="0,0,0,7">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="76" />
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TimeText}" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Level}" FontWeight="SemiBold" Foreground="#334155" />
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{Binding Message}" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
