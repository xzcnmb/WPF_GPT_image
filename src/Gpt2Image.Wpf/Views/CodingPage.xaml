<UserControl x:Class="Gpt2Image.Wpf.Views.CodingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <Style x:Key="CodingActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallActionButtonStyle}" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="AI 编码助手" Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock Text="参考 OpenCowork 的本地 AI 协作方式：支持 DeepSeek、Kimi、Qwen、GLM 等编码模型，项目上下文、计划任务、工具审批和验证输出在一个工作台内完成。"
                           Style="{StaticResource PageSubtitleTextStyle}" />
                <TextBlock Text="{Binding Status}" Style="{StaticResource StatusTextBlockStyle}" Margin="0,6,24,0" />
            </StackPanel>
            <Border Grid.Column="1" Style="{StaticResource StatusPillStyle}" VerticalAlignment="Top" Margin="18,4,0,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ShieldLockOutline" Width="16" Height="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,6,0" />
                    <TextBlock Text="Human-in-the-loop 审批" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" FontSize="12" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" MinWidth="320" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" MinWidth="460" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="480" MinWidth="420" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="项目工作区" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="打开本地仓库，建立安全文件树；敏感路径、大文件和二进制内容不会暴露给模型。"
                                   Style="{StaticResource SectionSubtitleTextStyle}" Margin="0,4,0,12" />
                        <Button Content="选择代码目录" Command="{Binding SelectWorkspaceCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                        <TextBox Text="{Binding WorkspacePath, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 Margin="0,10,0,0"
                                 materialDesign:HintAssist.Hint="选择一个本地项目目录" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="项目 / 会话" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="像 OpenCowork 一样，把项目上下文、检索和历史会话放在编码工作台左侧。" Style="{StaticResource SectionSubtitleTextStyle}" />
                        </StackPanel>

                        <TabControl Grid.Row="1">
                            <TabItem Header="项目上下文">
                                <Grid Margin="0,12,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="120" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="安全文件树" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="刷新" Command="{Binding RefreshWorkspaceExplorerCommand}" Style="{StaticResource CodingActionButtonStyle}" />
                                    </Grid>

                                    <Grid Grid.Row="1" Margin="0,10,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding WorkspaceSearchQuery, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="搜索文本 / 类名 / 方法名" />
                                        <Button Grid.Column="2" Content="搜索" Command="{Binding SearchWorkspaceCommand}" Style="{StaticResource CodingActionButtonStyle}" />
                                    </Grid>

                                    <ListBox Grid.Row="2" ItemsSource="{Binding WorkspaceFiles}" SelectedItem="{Binding SelectedWorkspaceFile}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource SoftListItemCardStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding DirectoryName}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="预览" Command="{Binding DataContext.ReadWorkspaceFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource CodingActionButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <ListBox Grid.Row="4" ItemsSource="{Binding WorkspaceSearchResults}" SelectedItem="{Binding SelectedSearchResult}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource SoftListItemCardStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding DisplayText}" FontFamily="Consolas" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding LineText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" MaxHeight="42" />
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="打开" Command="{Binding DataContext.OpenSearchResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource CodingActionButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Button Grid.Row="5" Content="复制预览" Command="{Binding CopyWorkspacePreviewCommand}" Style="{StaticResource CodingActionButtonStyle}" Margin="0,10,0,0" HorizontalAlignment="Right" />
                                </Grid>
                            </TabItem>

                            <TabItem Header="最近会话">
                                <Grid Margin="0,12,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="历史运行" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="刷新" Command="{Binding RefreshRunsCommand}" Style="{StaticResource CodingActionButtonStyle}" />
                                    </Grid>

                                    <Border Grid.Row="1" Style="{StaticResource MutedSectionCardStyle}" Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ShieldCheck" Width="18" Height="18" Foreground="{StaticResource SuccessBrush}" Margin="0,0,8,0" />
                                            <TextBlock Text="命令白名单：dotnet build/test、git status/diff" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <ListBox Grid.Row="2" ItemsSource="{Binding Runs}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource SoftListItemCardStyle}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Row="1" Text="{Binding Status}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3,0,0" />
                                                        <Button Grid.Row="2"
                                                                Content="加载会话"
                                                                Margin="0,8,0,0"
                                                                Style="{StaticResource CodingActionButtonStyle}"
                                                                Command="{Binding DataContext.LoadRunCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="150" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="目标、模式与计划" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="选择 Chat / Clarify / Cowork / Code / ACP 模式，AI 按对应方式生成计划、变更和验证建议。" Style="{StaticResource SectionSubtitleTextStyle}" />
                    </StackPanel>

                    <Border Grid.Row="1" Style="{StaticResource MutedSectionCardStyle}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox ItemsSource="{Binding SessionModes}"
                                          SelectedItem="{Binding SelectedSessionMode}"
                                          DisplayMemberPath="DisplayText"
                                          materialDesign:HintAssist.Hint="会话模式" />
                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding AvailableCodingProfiles}"
                                          SelectedItem="{Binding SelectedCodingProfile}"
                                          DisplayMemberPath="DisplayText"
                                          materialDesign:HintAssist.Hint="编码模型" />
                                <Button Grid.Column="3" Content="刷新模型" Command="{Binding RefreshCodingProfilesCommand}" Style="{StaticResource CodingActionButtonStyle}" Margin="8,0,0,0" />
                            </Grid>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding Goal, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         MinHeight="110"
                                         materialDesign:HintAssist.Hint="例如：修复登录页面空引用，并运行 dotnet build 验证。" />
                                <Button Grid.Column="1" Content="启动 Cowork" Command="{Binding StartRunCommand}" Style="{StaticResource PrimaryButtonStyle}" MinWidth="104" Margin="12,0,0,0" VerticalAlignment="Stretch" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource MutedSectionCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="计划 / Tasks" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding PlanItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFFFFF" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="8" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Index}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                                <TextBlock Grid.Column="1" Text="{Binding Text}" TextWrapping="Wrap" />
                                                <Border Grid.Column="2" Style="{StaticResource StatusPillStyle}" Padding="8,3" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Events}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="26" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid>
                                            <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,7,0,0" />
                                            <Border Width="2" Background="#DDE3EA" HorizontalAlignment="Center" Margin="0,20,0,-10" />
                                        </Grid>
                                        <Border Grid.Column="1" Style="{StaticResource SoftListItemCardStyle}" Margin="0,0,0,0">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="1" Text="{Binding CreatedAtText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="12,0,0,0" />
                                                </Grid>
                                                <TextBlock Text="{Binding Kind}" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0" />
                                                <TextBlock Text="{Binding Detail}" Foreground="#475569" TextWrapping="Wrap" Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="审批中心" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="所有文件写入和命令执行都必须先审批；失败输出会留存在会话中用于继续修复。" Style="{StaticResource SectionSubtitleTextStyle}" />
                    </StackPanel>

                    <TabControl Grid.Row="1">
                        <TabItem Header="文件变更">
                            <Grid Margin="0,12,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="120" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ListBox ItemsSource="{Binding FileChanges}" SelectedItem="{Binding SelectedFileChange}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SoftListItemCardStyle}">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding RelativePath}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                        <Border Grid.Column="1" Style="{StaticResource StatusPillStyle}" Padding="8,3" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" />
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Summary}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" MaxHeight="36" Margin="0,5,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBox Grid.Row="2"
                                         Text="{Binding SelectedFileChange.DiffText, Mode=OneWay}"
                                         Style="{StaticResource CodeViewerTextBoxStyle}" />

                                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                    <Button Content="复制 Diff" Command="{Binding CopyDiffCommand}" Style="{StaticResource CodingActionButtonStyle}" Margin="0,0,8,0" />
                                    <Button Content="拒绝" Command="{Binding RejectFileChangeCommand}" Style="{StaticResource CodingActionButtonStyle}" Margin="0,0,8,0" />
                                    <Button Content="应用变更" Command="{Binding ApproveFileChangeCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <TabItem Header="命令">
                            <Grid Margin="0,12,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="120" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ListBox ItemsSource="{Binding Commands}" SelectedItem="{Binding SelectedCommand}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SoftListItemCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Command}" FontFamily="Consolas" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Reason}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                        <Border Style="{StaticResource StatusPillStyle}" Padding="8,3" Margin="0,0,6,0">
                                                            <TextBlock Text="{Binding RiskLevel}" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" />
                                                        </Border>
                                                        <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" />
                                                        <TextBlock Text=" · " Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding WorkingDirectory}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBox Grid.Row="2"
                                         Text="{Binding SelectedCommand.DisplayOutput, Mode=OneWay}"
                                         Style="{StaticResource CodeViewerTextBoxStyle}" />

                                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                    <Button Content="复制命令" Command="{Binding CopyCommandCommand}" Style="{StaticResource CodingActionButtonStyle}" Margin="0,0,8,0" />
                                    <Button Content="拒绝" Command="{Binding RejectCommandCommand}" Style="{StaticResource CodingActionButtonStyle}" Margin="0,0,8,0" />
                                    <Button Content="运行命令" Command="{Binding ApproveCommandCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <TabItem Header="项目预览">
                            <Grid Margin="0,12,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="文件预览 / 搜索上下文" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <TextBox Grid.Row="1" Text="{Binding WorkspacePreviewText, Mode=OneWay}" Style="{StaticResource CodeViewerTextBoxStyle}" />
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
