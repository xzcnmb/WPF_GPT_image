<UserControl x:Class="Gpt2Image.Wpf.Views.ChatPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:Gpt2Image.Wpf.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:Base64ImageSourceConverter x:Key="Base64ImageSourceConverter" />
        <Style x:Key="ChatActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallActionButtonStyle}" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="AI 对话助手" Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock Text="支持 DeepSeek、MiniMax、Mino、Kimi、Qwen、GLM 等聊天兼容模型，文本、图片和代码附件会以更自然的会话卡片展示。" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
                <TextBlock Text="{Binding Status}" Style="{StaticResource StatusTextBlockStyle}" Margin="0,5,0,0" />
            </StackPanel>
            <ProgressBar Grid.Column="1"
                         Width="160"
                         Height="4"
                         IsIndeterminate="True"
                         VerticalAlignment="Center"
                         Visibility="{Binding IsSending, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="280" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" MinWidth="560" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="会话" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="新建" Command="{Binding NewConversationCommand}" Padding="10,4" />
                    </Grid>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Conversations}"
                             SelectedItem="{Binding SelectedConversation}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EDF0F4" BorderThickness="0,0,0,1" Padding="4,9" Margin="0,0,0,4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="42" />
                                        <Grid Margin="0,5,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Model}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{Binding UpdatedAtText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <Button Content="刷新" Command="{Binding RefreshConversationsCommand}" Margin="0,0,0,8" />
                        <Button Content="删除当前会话" Command="{Binding DeleteConversationCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="聊天内容" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="为新会话选择模型供应商，已有会话会继续使用创建时的模型。" Style="{StaticResource SectionSubtitleTextStyle}" />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding AvailableChatProfiles}"
                                  SelectedItem="{Binding SelectedChatProfile}"
                                  DisplayMemberPath="DisplayText"
                                  materialDesign:HintAssist.Hint="对话模型" />
                        <Button Grid.Column="2" Content="刷新模型" Command="{Binding RefreshChatProfilesCommand}" Style="{StaticResource ChatActionButtonStyle}" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="Bubble"
                                            MaxWidth="860"
                                            BorderBrush="{StaticResource SubtleBorderBrush}"
                                            BorderThickness="1"
                                            Background="#FFFFFF"
                                            CornerRadius="18"
                                            Padding="16"
                                            Margin="0,0,0,14"
                                            materialDesign:ElevationAssist.Elevation="Dp1"
                                            HorizontalAlignment="Left">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="24" Height="24" CornerRadius="12" Background="{StaticResource AccentSoftBrush}" Margin="0,0,8,0">
                                                        <materialDesign:PackIcon Kind="Robot" Width="15" Height="15" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" />
                                                    </Border>
                                                    <TextBlock Text="{Binding RoleText}" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding CreatedAtText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding Attachments}" Margin="0,0,0,8">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#CBD5E1" BorderThickness="1" Background="#F8FAFC" CornerRadius="12" Padding="8" Margin="0,0,8,8" Width="158" materialDesign:ElevationAssist.Elevation="Dp1">
                                                            <StackPanel>
                                                                <Image x:Name="AttachmentImage" Source="{Binding PreviewSource, Converter={StaticResource Base64ImageSourceConverter}}" Height="84" Stretch="UniformToFill" Visibility="Collapsed" />
                                                                <Border x:Name="AttachmentFile" Height="36" Background="#E2E8F0" Visibility="Visible" Margin="0,0,0,4">
                                                                    <TextBlock Text="文件" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" />
                                                                </Border>
                                                                <TextBlock Text="{Binding FileName}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding SizeText}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                                            </StackPanel>
                                                        </Border>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                                <Setter TargetName="AttachmentImage" Property="Visibility" Value="Visible" />
                                                                <Setter TargetName="AttachmentFile" Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <ItemsControl ItemsSource="{Binding Blocks}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,3,0,7">
                                                            <TextBlock x:Name="TextBlockPart"
                                                                       Text="{Binding Text}"
                                                                       TextWrapping="Wrap"
                                                                       FontSize="14"
                                                                       LineHeight="22"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       TextOptions.TextFormattingMode="Ideal" />
                                                            <Border x:Name="CodeBlockPart"
                                                                    Visibility="Collapsed"
                                                                    Background="#0F172A"
                                                                    BorderBrush="#1E293B"
                                                                    BorderThickness="1"
                                                                    CornerRadius="14"
                                                                    Padding="0"
                                                                    ClipToBounds="True">
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto" />
                                                                        <RowDefinition Height="Auto" />
                                                                    </Grid.RowDefinitions>
                                                                    <Border Background="#111827" Padding="8,5">
                                                                        <DockPanel LastChildFill="True">
                                                                            <Button Content="复制代码" Command="{Binding CopyCommand}" DockPanel.Dock="Right" Style="{StaticResource ChatActionButtonStyle}" />
                                                                            <TextBlock Text="{Binding Language}" Foreground="#CBD5E1" FontSize="12" VerticalAlignment="Center" />
                                                                        </DockPanel>
                                                                    </Border>
                                                                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="360">
                                                                        <TextBox Text="{Binding Text}"
                                                                                 IsReadOnly="True"
                                                                                 BorderThickness="0"
                                                                                 Background="#0F172A"
                                                                                 Foreground="#E2E8F0"
                                                                                 FontFamily="Consolas"
                                                                                 FontSize="13"
                                                                                 TextWrapping="NoWrap"
                                                                                 AcceptsReturn="True"
                                                                                 Padding="10" />
                                                                    </ScrollViewer>
                                                                </Grid>
                                                            </Border>
                                                        </Grid>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsCode}" Value="True">
                                                                <Setter TargetName="TextBlockPart" Property="Visibility" Value="Collapsed" />
                                                                <Setter TargetName="CodeBlockPart" Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                            <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right" />
                                            <Setter TargetName="Bubble" Property="Background" Value="#EFF6FF" />
                                            <Setter TargetName="Bubble" Property="BorderBrush" Value="#BFDBFE" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                            <Setter TargetName="Bubble" Property="Background" Value="#FEF2F2" />
                                            <Setter TargetName="Bubble" Property="BorderBrush" Value="#FCA5A5" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Grid.Row="2" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" Background="#FFFFFF" Padding="10" Margin="0,14,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ItemsControl ItemsSource="{Binding PendingAttachments}" Margin="0,0,0,8">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#CBD5E1" BorderThickness="1" Background="#F8FAFC" CornerRadius="12" Padding="8" Margin="0,0,8,8" Width="158" materialDesign:ElevationAssist.Elevation="Dp1">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Button Content="×"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Command="{Binding DataContext.RemoveAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        MinWidth="24"
                                                        MinHeight="24"
                                                        Padding="0" />
                                                <StackPanel Grid.Row="1">
                                                    <Image x:Name="PendingImage" Source="{Binding PreviewSource, Converter={StaticResource Base64ImageSourceConverter}}" Height="84" Stretch="UniformToFill" Visibility="Collapsed" />
                                                    <Border x:Name="PendingFile" Height="36" Background="#E2E8F0" Visibility="Visible" Margin="0,0,0,4">
                                                        <TextBlock Text="文件" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569" />
                                                    </Border>
                                                    <TextBlock Text="{Binding FileName}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding SizeText}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                <Setter TargetName="PendingImage" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="PendingFile" Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Content="添加附件" Command="{Binding AddAttachmentsCommand}" Style="{StaticResource ChatActionButtonStyle}" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         MinHeight="76"
                                         MaxHeight="150" />
                                <Button Grid.Column="4" Content="发送" Command="{Binding SendCommand}" Style="{StaticResource PrimaryButtonStyle}" MinWidth="96" />
                                <Button Grid.Column="6" Content="停止" Command="{Binding SendCancelCommand}" MinWidth="72" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
