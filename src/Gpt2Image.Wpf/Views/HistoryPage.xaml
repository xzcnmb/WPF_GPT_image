<UserControl x:Class="Gpt2Image.Wpf.Views.HistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="历史" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Status}" Style="{StaticResource StatusTextBlockStyle}" Margin="0,5,0,0" />
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" Background="{StaticResource PanelBrush}" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="任务" FontSize="18" FontWeight="SemiBold" />
                </Grid>

                <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#EDF0F4" BorderThickness="1" Padding="24">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520">
                        <TextBlock Text="暂无记录" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
