<UserControl x:Class="Gpt2Image.Wpf.Views.HistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Gpt2Image.Wpf.Converters">
    <UserControl.Resources>
        <converters:Base64ImageSourceConverter x:Key="Base64ImageSourceConverter" />
        <Style x:Key="HistoryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="历史" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Status}" Style="{StaticResource StatusTextBlockStyle}" Margin="0,5,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="刷新" Command="{Binding RefreshCommand}" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" MinWidth="300" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" MinWidth="520" />
            </Grid.ColumnDefinitions>

            <Border BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" Background="{StaticResource PanelBrush}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="任务" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Tasks}"
                             SelectedItem="{Binding SelectedTask}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EDF0F4" BorderThickness="0,0,0,1" Padding="4,8" Margin="0,0,0,4">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding ShortId}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Text="{Binding Model}" Foreground="{StaticResource TextSecondaryBrush}" />
                                        </Grid>
                                        <TextBlock Text="{Binding Prompt}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="44" Margin="0,5,0,4" />
                                        <TextBlock Text="{Binding Summary}" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding Error}" Foreground="#B91C1C" TextWrapping="Wrap" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" Background="{StaticResource PanelBrush}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="输出" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Outputs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemWidth="360" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="350" Height="456" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" Background="#F8FAFC" Margin="0,0,14,14">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="保存到..." Command="{Binding SaveAsCommand}" />
                                                <MenuItem Header="打开文件" Command="{Binding OpenFileCommand}" />
                                                <MenuItem Header="打开文件夹" Command="{Binding OpenFolderCommand}" />
                                                <MenuItem Header="复制路径" Command="{Binding CopyPathCommand}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="320" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Grid Background="#EEF2F7">
                                                <Image Source="{Binding PreviewImageSource, Converter={StaticResource Base64ImageSourceConverter}}" Stretch="Uniform" />
                                            </Grid>
                                            <Border Grid.Row="1" Background="#FFFFFF" Padding="10">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                        <TextBlock Grid.Column="1" Text="{Binding FileName}" Foreground="{StaticResource TextSecondaryBrush}" MaxWidth="150" TextTrimming="CharacterEllipsis" />
                                                    </Grid>
                                                    <TextBlock Grid.Row="1" Text="{Binding Status}" Foreground="#475569" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Margin="0,5,0,0" />
                                                    <UniformGrid Grid.Row="2" Columns="4" Margin="0,10,0,0">
                                                        <Button Content="保存" Command="{Binding SaveAsCommand}" Style="{StaticResource HistoryActionButtonStyle}" Margin="0,0,6,0" />
                                                        <Button Content="打开" Command="{Binding OpenFileCommand}" Style="{StaticResource HistoryActionButtonStyle}" Margin="0,0,6,0" />
                                                        <Button Content="文件夹" Command="{Binding OpenFolderCommand}" Style="{StaticResource HistoryActionButtonStyle}" Margin="0,0,6,0" />
                                                        <Button Content="复制路径" Command="{Binding CopyPathCommand}" Style="{StaticResource HistoryActionButtonStyle}" />
                                                    </UniformGrid>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
