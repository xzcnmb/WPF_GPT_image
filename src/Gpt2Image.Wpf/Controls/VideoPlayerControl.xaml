<UserControl x:Class="Gpt2Image.Wpf.Controls.VideoPlayerControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF">
    <UserControl.Resources>
        <Style x:Key="VideoPlaybackButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#475569" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0F766E" />
                    <Setter Property="BorderBrush" Value="#5EEAD4" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#115E59" />
                    <Setter Property="BorderBrush" Value="#99F6E4" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="#0F172A">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <vlc:VideoView x:Name="VideoView" />
                <TextBlock x:Name="PlaceholderText"
                           Text="视频可在线播放"
                           Foreground="#CBD5E1"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>

            <Border Grid.Row="1" Background="#111827" BorderBrush="#1F2937" BorderThickness="0,1,0,0" Padding="10,8">
                <DockPanel LastChildFill="True">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Content="▶ 播放" Click="OnPlayClicked" Style="{StaticResource VideoPlaybackButtonStyle}" Margin="0,0,8,0" />
                        <Button Content="Ⅱ 暂停" Click="OnPauseClicked" Style="{StaticResource VideoPlaybackButtonStyle}" Margin="0,0,8,0" />
                        <Button Content="■ 停止" Click="OnStopClicked" Style="{StaticResource VideoPlaybackButtonStyle}" />
                    </StackPanel>
                    <TextBlock Text="{Binding ElementName=Root, Path=StatusText, FallbackValue=就绪}"
                               x:Name="StatusBlock"
                               Foreground="#CBD5E1"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="12,0,0,0" />
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
