<UserControl x:Class="Gpt2Image.Wpf.Controls.VideoPlayerControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF">
    <Border Background="#0F172A">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <vlc:VideoView x:Name="VideoView" />
                <TextBlock x:Name="PlaceholderText"
                           Text="视频可在线播放"
                           Foreground="#CBD5E1"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>

            <Border Grid.Row="1" Background="#111827" Padding="8">
                <DockPanel LastChildFill="True">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Content="播放" Click="OnPlayClicked" MinHeight="28" Padding="10,3" Margin="0,0,6,0" />
                        <Button Content="暂停" Click="OnPauseClicked" MinHeight="28" Padding="10,3" Margin="0,0,6,0" />
                        <Button Content="停止" Click="OnStopClicked" MinHeight="28" Padding="10,3" />
                    </StackPanel>
                    <TextBlock Text="{Binding ElementName=Root, Path=StatusText, FallbackValue=就绪}"
                               x:Name="StatusBlock"
                               Foreground="#CBD5E1"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="12,0,0,0" />
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
