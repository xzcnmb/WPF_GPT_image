<Window x:Class="Gpt2Image.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Gpt2Image.Wpf.Views"
        xmlns:viewModels="clr-namespace:Gpt2Image.Wpf.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="GPT2Image Studio" Width="1440" Height="920" MinWidth="1180" MinHeight="780"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:CreatePageViewModel}">
            <views:CreatePage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:VideoGenerationPageViewModel}">
            <views:VideoGenerationPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:AgentPageViewModel}">
            <views:AgentPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ChatPageViewModel}">
            <views:ChatPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:HistoryPageViewModel}">
            <views:HistoryPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SettingsPageViewModel}">
            <views:SettingsPage />
        </DataTemplate>

        <Style x:Key="NavigationListBoxStyle" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="NavigationListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root" CornerRadius="14" Padding="12,11" Background="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E7F5F2" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0F766E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="NavigationItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon x:Name="Icon" Kind="{Binding Icon}" Width="22" Height="22" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#0F766E" />
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="Title" Text="{Binding Title}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" />
                    <TextBlock x:Name="Group" Text="{Binding Group}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                    <Setter TargetName="Icon" Property="Foreground" Value="#FFFFFF" />
                    <Setter TargetName="Title" Property="Foreground" Value="#FFFFFF" />
                    <Setter TargetName="Group" Property="Foreground" Value="#DDF7F2" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="42" Height="42" CornerRadius="13" Background="{StaticResource AccentBrush}" Margin="0,0,12,0">
                        <materialDesign:PackIcon Kind="Palette" Width="24" Height="24" Foreground="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="GPT2Image Studio" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="AI Creative Workspace" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#F8FAFC" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" CornerRadius="999" Padding="14,7">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ViewDashboard" Width="18" Height="18" Foreground="{StaticResource AccentBrush}" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#F8FAFC" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" CornerRadius="999" Padding="12,7">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseCheck" Width="18" Height="18" Foreground="{StaticResource SuccessBrush}" Margin="0,0,8,0" />
                            <TextBlock Text="本地工作区" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="286" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource AppCardStyle}" Padding="16">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="工作导航" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="创作、对话、历史和系统能力按工作区组织，后续新功能可直接加入。" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" FontSize="12" Margin="0,5,0,16" />
                        <ListBox ItemsSource="{Binding NavigationItems}"
                                 SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}"
                                 ItemTemplate="{StaticResource NavigationItemTemplate}"
                                 Style="{StaticResource NavigationListBoxStyle}"
                                 ItemContainerStyle="{StaticResource NavigationListBoxItemStyle}" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0">
                        <ListBox ItemsSource="{Binding FooterNavigationItems}"
                                 SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}"
                                 ItemTemplate="{StaticResource NavigationItemTemplate}"
                                 Style="{StaticResource NavigationListBoxStyle}"
                                 ItemContainerStyle="{StaticResource NavigationListBoxItemStyle}" />
                        <Border BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="0,1,0,0" Margin="0,14,0,0" Padding="0,14,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="队列" FontWeight="SemiBold" />
                                    <materialDesign:PackIcon Grid.Column="1" Kind="ProgressClock" Width="18" Height="18" Foreground="{StaticResource TextSecondaryBrush}" />
                                </Grid>
                                <ItemsControl ItemsSource="{Binding QueueItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F8FAFC" BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="9" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="暂无排队任务" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding QueueItems.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource AppCardStyle}" Padding="22" ClipToBounds="True">
                <ContentControl Content="{Binding CurrentPage}" />
            </Border>
        </Grid>
    </Grid>
</Window>
