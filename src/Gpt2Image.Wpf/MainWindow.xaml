<Window x:Class="Gpt2Image.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Gpt2Image.Wpf.Views"
        xmlns:viewModels="clr-namespace:Gpt2Image.Wpf.ViewModels"
        Title="GPT2Image WPF" Width="1320" Height="860" MinWidth="1040" MinHeight="720"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:CreatePageViewModel}">
            <views:CreatePage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:AgentPageViewModel}">
            <views:AgentPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ChatPageViewModel}">
            <views:ChatPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:HistoryPageViewModel}">
            <views:HistoryPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SettingsPageViewModel}">
            <views:SettingsPage />
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="224" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#111827">
            <DockPanel Margin="18,20">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="GPT2Image" Foreground="#FFFFFF" FontSize="24" FontWeight="SemiBold" />
                    <Button Content="创作" Command="{Binding ShowCreateCommand}" HorizontalContentAlignment="Left" Margin="0,26,0,8" />
                    <Button Content="自动任务" Command="{Binding ShowAgentCommand}" HorizontalContentAlignment="Left" Margin="0,0,0,8" />
                    <Button Content="对话" Command="{Binding ShowChatCommand}" HorizontalContentAlignment="Left" Margin="0,0,0,8" />
                    <Button Content="历史" Command="{Binding ShowHistoryCommand}" HorizontalContentAlignment="Left" Margin="0,0,0,8" />
                    <Button Content="设置" Command="{Binding ShowSettingsCommand}" HorizontalContentAlignment="Left" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,22,0,0">
                    <TextBlock Text="队列" Foreground="#FFFFFF" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding QueueItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#273244" BorderThickness="0,1,0,0" Padding="0,9">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Foreground="#D5DCE8" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Status}" Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Padding="24,20">
            <ContentControl Content="{Binding CurrentPage}" />
        </Border>
    </Grid>
</Window>
